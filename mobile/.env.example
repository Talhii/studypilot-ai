# Point the mobile client at your backend. On a physical device use your
# machine's LAN IP (find it with `ipconfig` / `ifconfig`), e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.20:8000
#
# Leave unset to use the per-platform dev defaults:
#   - Android emulator -> http://10.0.2.2:8000
#   - iOS simulator / web -> http://localhost:8000
EXPO_PUBLIC_API_URL=
